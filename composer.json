{
    "name": "caravanglory/module-antom",
    "description": "Antom payment integration for Magento 2 (Credit Card, Google Pay, Apple Pay)",
    "keywords": [
        "magento2",
        "payment",
        "antom",
        "alipay",
        "google pay",
        "apple pay",
        "credit card"
    ],
    "type": "magento2-module",
    "license": "MIT",
    "authors": [
        {
            "name": "CaravanGlory",
            "email": "info@caravanglory.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "magento/framework": ">=103.0",
        "magento/module-payment": ">=100.4",
        "magento/module-sales": ">=103.0",
        "magento/module-checkout": ">=100.4",
        "magento/module-quote": ">=101.2",
        "antom/global-open-sdk-php": "^1.0"
    },
    "suggest": {
        "hyva-themes/magento2-hyva-checkout": "Required for Hyvä Checkout integration (frontend payment forms)"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "CaravanGlory\\Antom\\": ""
        }
    }
}