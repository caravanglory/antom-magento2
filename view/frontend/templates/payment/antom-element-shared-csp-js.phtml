<?php
/**
 * Shared JS factory for Antom payment methods (Card, Google Pay, Apple Pay).
 * Registers each payment method with Hyvä Checkout via the payment API priority queue,
 * ensuring methods are registered before activation events fire.
 *
 * Uses AMSCashierPayment from the Antom Web SDK with createComponent() API
 * (the Element Integration entry point for productScene=ELEMENT_PAYMENT).
 *
 * This script MUST be placed in the hyva.checkout.api-v1.payment-methods container
 * (rendered inside api/v1.phtml) to guarantee correct timing.
 */

declare(strict_types=1);

use Hyva\Theme\ViewModel\HyvaCsp;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var HyvaCsp $hyvaCsp */
?>

<script>
    function antomRegisterPaymentMethod(config) {
        const METHOD_CODE = config.methodCode;
        const SDK_PAYMENT_METHOD_TYPE = config.sdkPaymentMethodType;
        const CONTAINER_ID = config.containerId;

        let elementInstance = null;
        let sdkLoaded = false;
        let submitting = false;
        let initializePromise = null;
        let refreshHookRegistered = false;

        function loadSdk() {
            return new Promise((resolve, reject) => {
                if (sdkLoaded || window.AMSElement) {
                    sdkLoaded = true;
                    resolve();
                    return;
                }
                const antomConfig = getAntomConfig();
                const sdkUrl = antomConfig.sdkUrl || '';
                if (!sdkUrl) {
                    reject(new Error('Antom SDK URL not configured'));
                    return;
                }
                const script = document.createElement('script');
                script.src = sdkUrl;
                script.addEventListener('load', () => {
                    sdkLoaded = true;
                    resolve();
                });
                script.addEventListener('error', () => reject(new Error('Failed to load Antom SDK from: ' + sdkUrl)));
                document.head.appendChild(script);
            });
        }

        function getAntomConfig() {
            try {
                return hyvaCheckout.config.getValue('antom') || {};
            } catch (e) {
                return {};
            }
        }

        async function createQuoteSession() {
            const antomConfig = getAntomConfig();
            const url = window.BASE_URL + (antomConfig.createQuoteSessionUrl || 'antom/payment/createquotesession');
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'include',
                body: JSON.stringify({
                    payment_method_type: SDK_PAYMENT_METHOD_TYPE
                })
            });

            if (!response.ok) {
                const errorData = await response.json().catch(() => ({}));
                throw new Error(errorData.message || 'Failed to create payment session');
            }

            return response.json();
        }

        async function queryOrderStatus() {
            const antomConfig = getAntomConfig();
            const url = window.BASE_URL + (antomConfig.orderStatusUrl || 'antom/payment/orderstatus');
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'include',
                body: JSON.stringify({})
            });

            const data = await response.json().catch(() => ({}));

            if (!response.ok) {
                throw new Error(data.message || 'Failed to determine payment status');
            }

            return data;
        }

        function sleep(ms) {
            return new Promise((resolve) => window.setTimeout(resolve, ms));
        }

        async function waitForOrderStatus() {
            let lastResult = null;

            for (let attempt = 0; attempt < 5; attempt += 1) {
                lastResult = await queryOrderStatus();

                if (lastResult.status === 'success' || lastResult.status === 'failed') {
                    return lastResult;
                }

                if (lastResult.status !== 'processing') {
                    return lastResult;
                }

                await sleep(3000);
            }

            return lastResult;
        }

        function getErrorMessage(error) {
            return error?.result?.errorMessage
                || error?.error?.message
                || error?.message
                || null;
        }

        function redirectToSuccess() {
            destroySdk();
            window.location.href = window.BASE_URL + 'checkout/onepage/success';
        }

        function redirectToProcessing() {
            destroySdk();
            const antomConfig = getAntomConfig();
            const path = antomConfig.processingUrl || 'antom/payment/processing';
            window.location.href = window.BASE_URL + path;
        }

        async function restoreOrder() {
            const antomConfig = getAntomConfig();
            const url = window.BASE_URL + (antomConfig.restoreOrderUrl || 'antom/payment/restoreorder');
            try {
                await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    credentials: 'include',
                    body: JSON.stringify({})
                });
            } catch (e) {
                // Non-fatal: restore failing must not hide the primary payment error.
                console.error('Antom restoreOrder failed', e);
            }
        }

        async function reMountElement() {
            destroySdk();
            // Brief delay lets the server-side restoreQuote settle before we
            // reserve a new order id + create a fresh Antom session.
            await new Promise((resolve) => window.setTimeout(resolve, 1000));
            try {
                await initializeElement();
            } catch (e) {
                console.error('Failed to re-mount Antom element', e);
            }
        }

        /**
         * Translate an Antom submitPayment() error into a user-facing Error.
         * When the error code is terminal (supportRetry=false) the caller-side
         * session cannot be reused; we cancel the Magento order and remount a
         * fresh session before throwing so the customer has a usable form.
         */
        async function handlePaymentError(error) {
            const info = window.antomGetErrorInfo
                ? window.antomGetErrorInfo(error && error.code)
                : { code: error && error.code, message: error && error.message, supportRetry: true };

            if (!info.supportRetry) {
                await restoreOrder();
                await reMountElement();
            }

            const finalError = new Error(info.message || (error && error.message) || 'Payment did not complete. Please try again.');
            finalError.antomErrorCode = info.code;
            finalError.antomRecoveryAttempted = true;
            throw finalError;
        }

        async function recoverPendingOrder(fallbackError) {
            let orderStatus;

            try {
                orderStatus = await waitForOrderStatus();
            } catch (error) {
                if (fallbackError) {
                    fallbackError.antomRecoveryAttempted = true;
                    throw fallbackError;
                }

                error.antomRecoveryAttempted = true;
                throw error;
            }

            if (orderStatus?.status === 'success') {
                redirectToSuccess();
                return true;
            }

            if (orderStatus?.status === 'processing') {
                const processingError = new Error(
                    orderStatus.message
                    || 'Payment is still processing. Please check your order status before placing another order.'
                );
                processingError.antomRecoveryAttempted = true;
                throw processingError;
            }

            if (orderStatus?.status === 'failed') {
                const failedError = new Error(
                    orderStatus.message
                    || getErrorMessage(fallbackError)
                    || 'Payment failed. Please try again.'
                );
                failedError.antomRecoveryAttempted = true;
                throw failedError;
            }

            if (fallbackError) {
                fallbackError.antomRecoveryAttempted = true;
                throw fallbackError;
            }

            const unknownError = new Error(orderStatus?.message || 'Payment did not complete. Please try again.');
            unknownError.antomRecoveryAttempted = true;
            throw unknownError;
        }

        function handleEventCallback() {
            // AMSElement resolves submitPayment() directly. Keep the callback wired for
            // SDK compatibility, but do not depend on legacy event codes here.
        }

        function getContainer() {
            return document.getElementById(CONTAINER_ID);
        }

        function hasMountedElement() {
            const container = getContainer();

            return !!container && container.childElementCount > 0;
        }

        function isMethodSelected() {
            if (hyvaCheckout.config.getValue('payment.method') === METHOD_CODE) {
                return true;
            }

            const radio = document.getElementById('payment-method-' + METHOD_CODE);

            return !!radio && radio.checked;
        }

        function destroySdk() {
            if (elementInstance) {
                try {
                    elementInstance.unmount();
                } catch (e) {
                    // SDK already unmounted
                }
                elementInstance = null;
            }
        }

        async function initializeElement() {
            if (initializePromise) {
                return initializePromise;
            }

            if (hasMountedElement()) {
                return;
            }

            initializePromise = (async () => {
                await loadSdk();
                destroySdk();

                const sessionResponse = await createQuoteSession();

                if (!sessionResponse.paymentSessionData) {
                    throw new Error('Invalid payment session response');
                }

                const antomConfig = getAntomConfig();

                elementInstance = new AMSElement({
                    sessionData: sessionResponse.paymentSessionData,
                    environment: antomConfig.sdkEnvironment || 'sandbox',
                    locale: document.documentElement.lang || 'en_US',
                    appearance: {
                        showSubmitButton: false
                    },
                    notRedirectAfterComplete: true,
                    analytics: {
                        enabled: false
                    },
                    onEventCallback: handleEventCallback
                });

                // AMSElement.mount() resolves even when mounting fails — the
                // error is carried on the resolved value, not as a rejection.
                // Treat a resolved-with-error as a hard failure so we don't
                // show the customer an empty container with no feedback.
                const mountResult = await elementInstance.mount(
                    { type: 'payment', notRedirectAfterComplete: true },
                    '#' + CONTAINER_ID
                );
                const mountError = mountResult && mountResult.error;
                if (mountError && (mountError.code || mountError.message)) {
                    elementInstance = null;
                    const info = window.antomGetErrorInfo
                        ? window.antomGetErrorInfo(mountError.code)
                        : { message: mountError.message };
                    throw new Error(info.message || mountError.message || 'Failed to load payment form.');
                }
            })().finally(() => {
                initializePromise = null;
            });

            return initializePromise;
        }

        function registerRefreshHook() {
            if (refreshHookRegistered) {
                return;
            }

            const attachHook = () => {
                if (!window.Magewire || typeof window.Magewire.hook !== 'function') {
                    return false;
                }

                refreshHookRegistered = true;

                window.Magewire.hook('message.processed', (message, component) => {
                    if (!component || component.id !== 'checkout.payment.methods') {
                        return;
                    }

                    // Magewire can redraw the payment method markup without re-firing
                    // Hyva's payment activation event for the already-selected method.
                    window.requestAnimationFrame(() => {
                        if (!isMethodSelected() || hasMountedElement()) {
                            return;
                        }

                        initializeElement().catch((error) => {
                            console.error('Failed to remount Antom payment element', error);
                        });
                    });
                });

                return true;
            };

            if (!attachHook()) {
                document.addEventListener('magewire:available', attachHook, { once: true });
            }
        }

        hyvaCheckout.payment.after(() => {
            registerRefreshHook();

            if (hyvaCheckout.payment.getByCode(METHOD_CODE)) {
                return;
            }

            hyvaCheckout.payment.registerMethod({
                code: METHOD_CODE,
                method: {
                    async initialize() {
                        await initializeElement();
                    },

                    async uninitialize() {
                        destroySdk();
                    },

                    async validate() {
                        return true;
                    },

                    async placeOrder({ fallback }) {
                        if (submitting) {
                            return;
                        }
                        if (!elementInstance) {
                            // Surface a real error instead of silently returning — a silent
                            // return lets Hyva treat order.place as a success and navigate
                            // to the confirmation page even though nothing was charged.
                            throw new Error('Payment form is not ready. Please wait a moment and try again.');
                        }
                        submitting = true;

                        try {
                            // Antom resolves submitPayment() with the payment result. The
                            // Magento order must exist before submission so Antom can look
                            // up the reference order during payment processing.
                            await fallback();

                            const paymentResult = await elementInstance.submitPayment();
                            const status = paymentResult && paymentResult.status;
                            const error = paymentResult && paymentResult.error;
                            const userCanceled3D = paymentResult && paymentResult.userCanceled3D;

                            if (status === 'SUCCESS' && !error) {
                                redirectToSuccess();
                                return;
                            }

                            // 3DS cancellation and in-flight processing aren't hard failures;
                            // the authoritative status lives server-side and will arrive via
                            // Antom's async notification. Park the user on the processing
                            // page so it polls /antom/payment/orderstatus.
                            if (userCanceled3D || status === 'PROCESSING' || status === 'PENDING') {
                                redirectToProcessing();
                                return;
                            }

                            if (error) {
                                await handlePaymentError(error);
                                return;
                            }

                            // SDK returned neither success nor error (unexpected shape).
                            // Fall back to the server-side status poller to decide.
                            await recoverPendingOrder(
                                new Error('Payment did not complete. Please try again.')
                            );
                        } catch (e) {
                            if (e && e.antomRecoveryAttempted) {
                                throw e;
                            }
                            await recoverPendingOrder(e);
                        } finally {
                            submitting = false;
                        }
                    },

                    async canRedirect() {
                        return false;
                    },

                    async getRedirectUrl() {
                        return null;
                    }
                }
            });
        });
    }
</script>
<?php $hyvaCsp->registerInlineScript(); ?>
