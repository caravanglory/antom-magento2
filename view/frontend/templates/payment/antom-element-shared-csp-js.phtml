<?php
/**
 * Shared JS factory for Antom payment methods (Card, Google Pay, Apple Pay).
 * Registers each payment method with Hyvä Checkout via the payment API priority queue,
 * ensuring methods are registered before activation events fire.
 *
 * Uses AMSCashierPayment from the Antom Web SDK with createComponent() API
 * (the Element Integration entry point for productScene=ELEMENT_PAYMENT).
 *
 * This script MUST be placed in the hyva.checkout.api-v1.payment-methods container
 * (rendered inside api/v1.phtml) to guarantee correct timing.
 */

declare(strict_types=1);

use Hyva\Theme\ViewModel\HyvaCsp;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var HyvaCsp $hyvaCsp */
?>

<script>
    function antomRegisterPaymentMethod(config) {
        const METHOD_CODE = config.methodCode;
        const SDK_PAYMENT_METHOD_TYPE = config.sdkPaymentMethodType;
        const CONTAINER_ID = config.containerId;

        let elementInstance = null;
        let sdkLoaded = false;
        let submitting = false;
        let paymentResolve = null;
        let paymentReject = null;

        function loadSdk() {
            return new Promise((resolve, reject) => {
                if (sdkLoaded || window.AMSElement) {
                    sdkLoaded = true;
                    resolve();
                    return;
                }
                const antomConfig = getAntomConfig();
                const sdkUrl = antomConfig.sdkUrl || '';
                if (!sdkUrl) {
                    reject(new Error('Antom SDK URL not configured'));
                    return;
                }
                const script = document.createElement('script');
                script.src = sdkUrl;
                script.addEventListener('load', () => {
                    sdkLoaded = true;
                    resolve();
                });
                script.addEventListener('error', () => reject(new Error('Failed to load Antom SDK from: ' + sdkUrl)));
                document.head.appendChild(script);
            });
        }

        function getAntomConfig() {
            try {
                return hyvaCheckout.config.getValue('antom') || {};
            } catch (e) {
                return {};
            }
        }

        async function createQuoteSession() {
            const antomConfig = getAntomConfig();
            const url = window.BASE_URL + (antomConfig.createQuoteSessionUrl || 'antom/payment/createquotesession');
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'include',
                body: JSON.stringify({
                    payment_method_type: SDK_PAYMENT_METHOD_TYPE
                })
            });

            if (!response.ok) {
                const errorData = await response.json().catch(() => ({}));
                throw new Error(errorData.message || 'Failed to create payment session');
            }

            return response.json();
        }

        function handleEventCallback(eventCode) {
            if (eventCode === 'SDK_PAYMENT_SUCCESSFUL') {
                paymentResolve && paymentResolve(true);
            } else if (eventCode === 'SDK_PAYMENT_FAIL' || eventCode === 'SDK_PAYMENT_ERROR') {
                submitting = false;
                paymentReject && paymentReject(new Error('Payment failed. Please try again.'));
            } else if (eventCode === 'SDK_PAYMENT_CANCEL') {
                submitting = false;
                paymentReject && paymentReject(new Error('Payment cancelled'));
            }
        }

        function destroySdk() {
            if (elementInstance) {
                try {
                    elementInstance.unmount();
                } catch (e) {
                    // SDK already unmounted
                }
                elementInstance = null;
            }
        }

        hyvaCheckout.payment.after(() => {
            if (hyvaCheckout.payment.getByCode(METHOD_CODE)) {
                return;
            }

            hyvaCheckout.payment.registerMethod({
                code: METHOD_CODE,
                method: {
                    async initialize() {
                        await loadSdk();

                        const sessionResponse = await createQuoteSession();

                        if (!sessionResponse.paymentSessionData) {
                            throw new Error('Invalid payment session response');
                        }

                        const antomConfig = getAntomConfig();

                        elementInstance = new AMSElement({
                            sessionData: sessionResponse.paymentSessionData,
                            environment: antomConfig.sdkEnvironment || 'sandbox',
                            locale: document.documentElement.lang || 'en_US',
                            appearance: {
                                showSubmitButton: false
                            },
                            notRedirectAfterComplete: true,
                            analytics: {
                                enabled: false
                            },
                            onEventCallback: handleEventCallback
                        });

                        await elementInstance.mount({}, '#' + CONTAINER_ID);
                    },

                    async uninitialize() {
                        destroySdk();
                    },

                    async validate() {
                        return true;
                    },

                    async placeOrder({ fallback }) {
                        if (submitting || !elementInstance) return;
                        submitting = true;

                        try {
                            const paymentResult = await new Promise((resolve, reject) => {
                                paymentResolve = resolve;
                                paymentReject = reject;
                                elementInstance.submitPayment();
                            });

                            if (paymentResult) {
                                await fallback();
                                destroySdk();
                                window.location.href = window.BASE_URL + 'checkout/onepage/success';
                            }
                        } catch (error) {
                            submitting = false;
                            throw error;
                        }
                    },

                    async canRedirect() {
                        return false;
                    },

                    async getRedirectUrl() {
                        return null;
                    }
                }
            });
        });
    }
</script>
<?php $hyvaCsp->registerInlineScript(); ?>
