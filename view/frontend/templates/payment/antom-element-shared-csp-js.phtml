<?php
/**
 * Shared JS factory for Antom Element-based payment methods (Card, Google Pay, Apple Pay).
 * Each method template calls antomElementPayment() with its specific config.
 */

declare(strict_types=1);

use Hyva\Theme\ViewModel\HyvaCsp;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var HyvaCsp $hyvaCsp */
?>

<script>
    function antomElementPayment(config) {
        const METHOD_CODE = config.methodCode;
        const SDK_PAYMENT_METHOD_TYPE = config.sdkPaymentMethodType;
        const CONTAINER_ID = config.containerId;

        let amsElement = null;
        let sdkLoaded = false;
        let submitting = false;

        function loadSdk() {
            return new Promise((resolve, reject) => {
                if (sdkLoaded || window.AMSElement) {
                    sdkLoaded = true;
                    resolve();
                    return;
                }
                const antomConfig = getAntomConfig();
                const sdkUrl = antomConfig.sdkUrl || '';
                if (!sdkUrl) {
                    reject(new Error('Antom SDK URL not configured'));
                    return;
                }
                const script = document.createElement('script');
                script.src = sdkUrl;
                script.addEventListener('load', () => {
                    sdkLoaded = true;
                    resolve();
                });
                script.addEventListener('error', () => reject(new Error('Failed to load Antom SDK')));
                document.head.appendChild(script);
            });
        }

        function getAntomConfig() {
            try {
                return hyvaCheckout.config.getValue('antom') || {};
            } catch (e) {
                return {};
            }
        }

        function getCreateSessionUrl() {
            const antomConfig = getAntomConfig();
            return antomConfig.createSessionUrl || 'antom/payment/createsession';
        }

        async function createPaymentSession(incrementId) {
            const url = window.BASE_URL + getCreateSessionUrl();
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'include',
                body: JSON.stringify({
                    order_increment_id: incrementId,
                    payment_method_type: SDK_PAYMENT_METHOD_TYPE
                })
            });

            if (!response.ok) {
                const errorData = await response.json().catch(() => ({}));
                throw new Error(errorData.message || 'Failed to create payment session');
            }

            return response.json();
        }

        function destroySdk() {
            if (amsElement) {
                try {
                    amsElement.destroy();
                } catch (e) {
                    // SDK already destroyed or not mounted
                }
                amsElement = null;
            }
        }

        return {
            loading: false,
            errorMessage: '',

            init() {
                hyvaCheckout.payment.registerMethod({
                    code: METHOD_CODE,

                    async initialize() {
                        await loadSdk();
                    },

                    async uninitialize() {
                        destroySdk();
                    },

                    async validate() {
                        return true;
                    },

                    async placeOrder({ fallback }) {
                        if (submitting) return;
                        submitting = true;

                        try {
                            await fallback();

                            const order = hyvaCheckout.main.getWireComponent();
                            const incrementId = order.get('order_increment_id')
                                || hyvaCheckout.storage.getData('order_increment_id')
                                || '';

                            if (!incrementId) {
                                throw new Error('Order was not created. Please try again.');
                            }

                            const sessionResponse = await createPaymentSession(incrementId);

                            if (!sessionResponse.paymentSessionData) {
                                throw new Error('Invalid payment session response');
                            }

                            const antomConfig = getAntomConfig();

                            amsElement = new AMSElement({
                                environment: antomConfig.sdkEnvironment || 'sandbox',
                                locale: document.documentElement.lang || 'en_US',
                                sessionData: sessionResponse.paymentSessionData
                            });

                            return new Promise((resolve, reject) => {
                                amsElement.mount({
                                    paymentMethodType: SDK_PAYMENT_METHOD_TYPE,
                                    onEventCallback: (event) => {
                                        if (event.code === 'SDK_PAYMENT_SUCCESSFUL') {
                                            destroySdk();
                                            window.location.href = window.BASE_URL + 'checkout/onepage/success';
                                            resolve(true);
                                        } else if (event.code === 'SDK_PAYMENT_FAIL'
                                            || event.code === 'SDK_PAYMENT_ERROR') {
                                            destroySdk();
                                            submitting = false;
                                            const msg = event.message || 'Payment failed. Please try again.';
                                            hyvaCheckout.message.alert(msg);
                                            reject(new Error(msg));
                                        } else if (event.code === 'SDK_PAYMENT_CANCEL') {
                                            destroySdk();
                                            submitting = false;
                                            hyvaCheckout.message.warn('Payment was cancelled.');
                                            reject(new Error('Payment cancelled'));
                                        }
                                    }
                                }, '#' + CONTAINER_ID);

                                amsElement.submitPayment();
                            });
                        } catch (error) {
                            destroySdk();
                            submitting = false;
                            throw error;
                        }
                    },

                    async canRedirect() {
                        return false;
                    },

                    async getRedirectUrl() {
                        return null;
                    }
                });
            }
        };
    }
</script>
<?php $hyvaCsp->registerInlineScript(); ?>
