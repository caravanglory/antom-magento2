<?php

declare(strict_types=1);

use Hyva\Theme\ViewModel\HyvaCsp;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var HyvaCsp $hyvaCsp */

$methodCode = 'antom_hosted';
?>

<script>
    (function() {
        const METHOD_CODE = '<?= $escaper->escapeJs($methodCode) ?>';

        hyvaCheckout.payment.after(() => {
            if (hyvaCheckout.payment.getByCode(METHOD_CODE)) {
                return;
            }

            hyvaCheckout.payment.registerMethod({
                code: METHOD_CODE,
                method: {
                    async initialize() {
                        // No SDK to load for hosted payment
                    },

                    async uninitialize() {
                        // No cleanup needed
                    },

                    async validate() {
                        return true;
                    },

                    async placeOrder({ fallback }) {
                        await fallback();
                    },

                    async canRedirect() {
                        return true;
                    },

                    async getRedirectUrl() {
                        // Redirect URL is provided by AntomHostedPlaceOrderService
                        return null;
                    }
                }
            });
        });
    })();
</script>
<?php $hyvaCsp->registerInlineScript(); ?>
