<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="antom-sdk" type="host">*.antom.com</value>
                <value id="antom-alipay-tracker" type="host">*.alipayobjects.com</value>
                <value id="antom-marmot-tracker" type="host">*.marmot-cloud.com</value>
                <value id="alipay-sdk" type="host">*.alipay.com</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="google-pay-frame" type="host">https://pay.google.com</value>
                <value id="alipay-frame" type="host">*.alipay.com</value>
                <value id="antom-frame" type="host">*.antom.com</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="antom-api" type="host">*.antom.com</value>
                <value id="antom-alipay-tracker" type="host">*.alipayobjects.com</value>
                <value id="antom-marmot-tracker" type="host">*.marmot-cloud.com</value>
                <value id="alipay-api" type="host">*.alipay.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>